generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id                 String              @id @default(cuid())
  formType           String
  email              String
  status             String              @default("new")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  name               String?
  message            String?
  country            String?
  industry           String?
  company            String?
  service            String?
  budget             String?
  recruiterName      String?
  companyName        String?
  jobTitle           String?
  jobDescription     String?
  salaryOffer        String?
  contractType       String?
  linkedin           String?
  portfolio          String?
  expertise          String?
  subject            String?
  inviterName        String?
  eventName          String?
  eventType          String?
  proposedRole       String?
  eventDate          DateTime?
  eventTime          String?
  eventLocation      String?
  invitationReason   String?
  tags               String[]            @default([])
  phone              String?
  activityLogs       ActivityLog[]
  campaignRecipients CampaignRecipient[]
  inboundEmails      InboundEmail[]

  @@index([formType])
  @@index([email])
  @@index([createdAt])
  @@index([status])
  @@map("contacts")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user")
  accounts      Account[]
  posts         Post[]
  sessions      Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Post {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  content        String
  excerpt        String?
  coverImage     String?
  published      Boolean   @default(false)
  featured       Boolean   @default(false)
  seoTitle       String?
  seoDescription String?
  keywords       String?
  authorId       String
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  comments       Comment[]
  author         User      @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([published])
  @@map("posts")
}

model SenderIdentity {
  id        String          @id @default(cuid())
  name      String
  email     String
  verified  Boolean         @default(false)
  isDefault Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  campaigns EmailCampaign[]

  @@map("sender_identities")
}

model EmailTemplate {
  id          String          @id @default(cuid())
  name        String
  description String?
  subject     String?
  content     String
  category    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  campaigns   EmailCampaign[]

  @@map("email_templates")
}

model EmailCampaign {
  id             String              @id @default(cuid())
  name           String
  subject        String
  content        String
  status         String              @default("draft")
  scheduledAt    DateTime?
  sentAt         DateTime?
  audienceFilter Json?
  recipientCount Int                 @default(0)
  statsSent      Int                 @default(0)
  statsDelivered Int                 @default(0)
  statsOpened    Int                 @default(0)
  statsClicked   Int                 @default(0)
  senderId       String
  templateId     String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  attachments    Json?
  recipients     CampaignRecipient[]
  sender         SenderIdentity      @relation(fields: [senderId], references: [id])
  template       EmailTemplate?      @relation(fields: [templateId], references: [id])

  @@map("email_campaigns")
}

model CampaignRecipient {
  id         String        @id @default(cuid())
  email      String
  status     String        @default("pending")
  openedAt   DateTime?
  clickedAt  DateTime?
  campaignId String
  contactId  String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  campaign   EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact    Contact?      @relation(fields: [contactId], references: [id])

  @@index([campaignId])
  @@index([email])
  @@map("campaign_recipients")
}

model ActivityLog {
  id        String   @id @default(cuid())
  contactId String?
  type      String
  title     String
  metadata  Json?
  createdAt DateTime @default(now())
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([createdAt])
  @@map("activity_logs")
}

model Comment {
  id          String   @id @default(cuid())
  content     String
  postId      String
  authorName  String?
  authorEmail String
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("comments")
}

model Subscriber {
  id         String   @id @default(cuid())
  email      String   @unique
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("subscribers")
}

model ProfileBase {
  id           String        @id @default(cuid())
  name         String
  email        String
  phone        String?
  location     String?
  summary      String
  experience   Json
  skills       Json
  education    Json
  projects     Json?
  languages    Json?
  socialLinks  Json?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  citizenship  String?
  documentId   String?
  applications Application[]

  @@map("profile_bases")
}

model JobVacancy {
  id                 String        @id @default(cuid())
  sourceType         String
  sourceContent      String
  sourceImage        String?
  company            String?
  position           String?
  location           String?
  workMode           String?
  salaryRange        String?
  analysis           Json?
  requirements       Json?
  keywords           String[]
  compatibilityScore Int?
  suggestions        String?
  status             String        @default("pending")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  applications       Application[]

  @@index([status])
  @@index([createdAt])
  @@map("job_vacancies")
}

model Application {
  id             String      @id @default(cuid())
  vacancyId      String
  profileId      String
  cvContent      Json
  cvPdfUrl       String?
  cvFileName     String?
  emailSubject   String
  emailHtml      String
  emailText      String
  recipientEmail String?
  recipientName  String?
  sentAt         DateTime?
  resendId       String?
  status         String      @default("draft")
  notes          String?
  followUpDate   DateTime?
  responseAt     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  profile        ProfileBase @relation(fields: [profileId], references: [id])
  vacancy        JobVacancy  @relation(fields: [vacancyId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([vacancyId])
  @@index([createdAt])
  @@map("applications")
}

model InboundEmail {
  id          String   @id @default(cuid())
  messageId   String   @unique
  fromEmail   String
  fromName    String?
  toEmail     String
  subject     String
  text        String?
  html        String?
  inReplyTo   String?
  attachments Json?
  read        Boolean  @default(false)
  archived    Boolean  @default(false)
  receivedAt  DateTime
  createdAt   DateTime @default(now())
  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([receivedAt])
  @@index([read])
  @@index([archived])
  @@index([contactId])
  @@index([fromEmail])
  @@map("inbound_emails")
}

model CVTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  structure   Json
  styles      Json
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("cv_templates")
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  visitorId String?
  referrer  String?
  device    String?
  browser   String?
  os        String?
  country   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([visitorId])
  @@index([path])
  @@map("page_views")
}
